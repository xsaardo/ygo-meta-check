# Database
POSTGRES_PASSWORD=ygo_secret

# Scraper
SCRAPER_MONTHS_LOOKBACK=3
SCRAPER_WORKERS=5
SCRAPER_DELAY_SECONDS=1.5
ALLOW_MANUAL_SCRAPE=false

# Card images storage path (absolute path on the host / container)
CARD_IMAGES_DIR=/app/card_images

# Production only — set these when deploying
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
# ALLOWED_ORIGINS=https://your-frontend.railway.app
# NEXT_PUBLIC_API_URL=https://your-backend.railway.app
# BACKEND_INTERNAL_URL=http://backend.railway.internal:8000
